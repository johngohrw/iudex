{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/forms/**",
              "ui_kits/live-session/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Sans|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Sans, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|variant|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, color, variant, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:pill|dot|outline)$/]",
        "message": "<Badge> variant must be one of 'pill' | 'dot' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|active|disabled|icon|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, active, disabled, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|primary|record|cyan|ghost)$/]",
        "message": "<Button> variant must be one of 'default' | 'primary' | 'record' | 'cyan' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Button> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|tone|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, label, tone, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:canvas|module)$/]",
        "message": "<Checkbox> tone must be one of 'canvas' | 'module'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContextMenuItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|shortcut|checked|disabled|danger|onSelect|divider|key|ref|className|style|children)$/]",
        "message": "<ContextMenuItem> doesn't accept that prop. Declared props: label, shortcut, checked, disabled, danger, onSelect, divider."
      },
      {
        "selector": "JSXOpeningElement[name.name='DropdownOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<DropdownOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Knob'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|min|max|size|accent|label|unit|precision|display|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Knob> doesn't accept that prop. Declared props: value, onChange, min, max, size, accent, label, unit, precision, display, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|selected|color|alt|height|onClick|right|tone|style|key|ref|className|style|children)$/]",
        "message": "<ListRow> doesn't accept that prop. Declared props: children, selected, color, alt, height, onClick, right, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListRow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:canvas|module)$/]",
        "message": "<ListRow> tone must be one of 'canvas' | 'module'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Meter'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|peak|width|height|style|key|ref|className|style|children)$/]",
        "message": "<Meter> doesn't accept that prop. Declared props: level, peak, width, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='GraphNode'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|title|x|y|color|inputs|outputs|key|ref|className|style|children)$/]",
        "message": "<GraphNode> doesn't accept that prop. Declared props: id, title, x, y, color, inputs, outputs."
      },
      {
        "selector": "JSXOpeningElement[name.name='NumericField'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|min|max|step|precision|unit|sensitivity|label|width|disabled|style|key|ref|className|style|children)$/]",
        "message": "<NumericField> doesn't accept that prop. Declared props: value, onChange, min, max, step, precision, unit, sensitivity, label, width, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|color|tone|collapsible|defaultCollapsed|headerRight|padded|children|style|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: title, color, tone, collapsible, defaultCollapsed, headerRight, padded, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:canvas|module)$/]",
        "message": "<Panel> tone must be one of 'canvas' | 'module'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PanelHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|color|collapsed|onToggle|tone|right|style|key|ref|className|style|children)$/]",
        "message": "<PanelHeader> doesn't accept that prop. Declared props: title, color, collapsed, onToggle, tone, right, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PanelHeader'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:canvas|module)$/]",
        "message": "<PanelHeader> tone must be one of 'canvas' | 'module'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RadioOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<RadioOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slider'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|min|max|orientation|accent|length|tone|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Slider> doesn't accept that prop. Declared props: value, onChange, min, max, orientation, accent, length, tone, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slider'] > JSXAttribute[name.name='orientation'] > Literal[value!=/^(?:horizontal|vertical)$/]",
        "message": "<Slider> orientation must be one of 'horizontal' | 'vertical'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slider'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:canvas|module)$/]",
        "message": "<Slider> tone must be one of 'canvas' | 'module'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TableColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|align|width|mono|render|key|ref|className|style|children)$/]",
        "message": "<TableColumn> doesn't accept that prop. Declared props: key, label, align, width, mono, render."
      },
      {
        "selector": "JSXOpeningElement[name.name='TableColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<TableColumn> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|tone|rows|width|disabled|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: value, onChange, placeholder, tone, rows, width, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:canvas|module)$/]",
        "message": "<Textarea> tone must be one of 'canvas' | 'module'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|tone|width|disabled|key|ref|className|style|children)$/]",
        "message": "<TextInput> doesn't accept that prop. Declared props: value, onChange, placeholder, tone, width, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextInput'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:canvas|module)$/]",
        "message": "<TextInput> tone must be one of 'canvas' | 'module'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:on|onChange|size|disabled|children|style|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: on, onChange, size, disabled, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Toggle> size must be one of 'sm' | 'md'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
